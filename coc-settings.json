{
  "suggest.noselect": false,

  "diagnostic.virtualText": true,
  "diagnostic.virtualTextCurrentLineOnly": true,

  "clangd.path": "clangd",
  "clangd.checkUpdates": false,
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--completion-style=detailed",
    "--header-insertion=iwyu"
  ],

  "pyright.organizeimports.provider": "ruff"
}
